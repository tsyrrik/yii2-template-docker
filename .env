APP_NAME=platform

APP_ENV=dev
APP_DEBUG=1
APP_SECRET=change-me-in-.env.local

DB_HOST=db
DB_PORT=3306
DB_NAME=app
DB_USER=app
DB_PASSWORD=change-me-in-.env.local

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DATABASE=0

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=app
RABBITMQ_PASSWORD=change-me-in-.env.local
RABBITMQ_VHOST=%2F
RABBITMQ_QUEUE=default

# Host-exposed ports
APP_HTTP_PORT=8080
APP_DB_PORT=3306
APP_REDIS_PORT=6379
APP_REDIS_MEMORY_LIMIT=512mb
APP_RABBITMQ_PORT=5672
APP_RABBITMQ_MGMT_PORT=15672

# MySQL backup (production service only)
MYSQL_BACKUP_CRON=17 3 * * *
MYSQL_BACKUP_RUN_ON_START=1
MYSQL_BACKUP_KEEP_DAYS=14
MYSQL_BACKUP_PREFIX=mysql
MYSQL_BACKUP_NAME=yii2-template-docker
MYSQL_BACKUP_S3_ENABLED=1
MYSQL_BACKUP_S3_ENDPOINT=https://s3.ru1.storage.beget.cloud
MYSQL_BACKUP_S3_REGION=ru1
MYSQL_BACKUP_S3_BUCKET=
MYSQL_BACKUP_S3_ACCESS_KEY=
MYSQL_BACKUP_S3_SECRET_KEY=
MYSQL_BACKUP_S3_PREFIX=mysql
MYSQL_BACKUP_S3_KEEP_DAYS=14
MYSQL_BACKUP_S3_PATH_STYLE=1

# Monitoring ports (monitoring compose only)
APP_PROMETHEUS_PORT=9090
APP_GRAFANA_PORT=3000
APP_MYSQL_EXPORTER_PORT=9104
APP_REDIS_EXPORTER_PORT=9121
APP_RABBITMQ_EXPORTER_PORT=9419
APP_PHP_FPM_EXPORTER_PORT=9253
APP_LOKI_PORT=3100
APP_GRAFANA_ADMIN_USER=admin
APP_GRAFANA_ADMIN_PASSWORD=change-me-in-.env.local
