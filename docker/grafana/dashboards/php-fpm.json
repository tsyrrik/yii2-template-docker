{
  "title": "PHP-FPM Overview",
  "uid": "php-fpm-overview",
  "schemaVersion": 38,
  "panels": [
    {
      "type": "timeseries",
      "title": "Accepted Connections",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "phpfpm_accepted_connections_total", "legendFormat": "accepted"}],
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8}
    },
    {
      "type": "timeseries",
      "title": "Active Processes",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "phpfpm_active_processes", "legendFormat": "active"}],
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8}
    }
  ]
}
